{
  "name": "@cairn/web",
  "version": "0.0.0",
  "private": true,
  "description": "cairn landing site — Next.js on Vercel (independent of the desktop app; not versioned/released with it).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "auth:generate": "better-auth generate --config lib/auth.ts --output lib/auth-schema.ts -y",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "better-auth": "^1.6.20",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.9",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.0",
    "eslint-config-next": "^16.2.9",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
